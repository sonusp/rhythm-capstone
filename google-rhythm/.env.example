# Google Rhythm — Environment Variables
# Copy this file to .env.local and fill in your values
# Last updated: 2026-06-19

# ============================================
# CLIENT-SIDE (safe — used by Vite build)
# ============================================
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ============================================
# SERVER-SIDE ONLY (Vercel Functions — NEVER prefix with VITE_)
# These are ONLY used by /api/* serverless functions on Vercel
# ============================================

# Primary AI — NVIDIA NIM (Llama 3.1 70B)
NVIDIA_API_KEY=nvapi-your_nvidia_nim_key_here

# Fallback AI + ASR — Groq (Llama 3.3 70B + Whisper v3 Turbo)
GROQ_API_KEY=gsk_your_groq_key_here

# Fallback AI — OpenRouter (free tier)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Fallback ASR — Deepgram Nova-2-Medical
DEEPGRAM_API_KEY=your_deepgram_key_here

# Google Gemini AI (for daily insights + clinical reports)
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# ============================================
# DEPRECATED — Remove from production .env.local
# These exposed keys to browser devtools. Replaced by serverless proxy.
# ============================================
# VITE_NVIDIA_API_KEY=DEPRECATED
# VITE_GROQ_API_KEY=DEPRECATED
# VITE_GEMINI_API_KEY=DEPRECATED
# VITE_DEEPGRAM_API_KEY=DEPRECATED
